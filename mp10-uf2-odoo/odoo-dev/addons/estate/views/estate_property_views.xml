<?xml version="1.0"?>
<odoo>
    <record id="estate_property_list" model="ir.ui.view">
        <field name="name">estate.property.list</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <list string="Properties">
                <field name="name"/>
                <field name="property_type_id"/>
                <field name="postcode"/>
                <field name="date_availability"/>
                <field name="expected_price"/>
                <field name="salesperson_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="estate_property_view_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form string="Property">
                <header>
                    <button name="cancellarPropietat" type="object" string="Cancel·lar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" nolabel="1"/>
                        </h1>
                        <field name="tag_ids" widget="many2many_tags" nolabel="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="property_type_id"/>
                            <field name="state"/>
                            <field name="postcode"/>
                            <field name="date_availability"/>
                        </group>
                        <group>
                            <field name="expected_price"/>
                            <field name="best_offer"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Descripció">
                            <group>
                                <field name="description"/>
                                <field name="selling_price"/>
                                <field name="avgPrice"/>
                                <field name="bedrooms"/>
                                <field name="surface"/>
                                <field name="elevator"/>
                                <field name="parking"/>
                                <field name="renovated"/>
                                <field name="bathrooms"/>
                                <field name="construction_year"/>
                                <field name="energy_certificate"/>
                                <field name="buyer_id"/>
                                <field name="salesperson_id"/>
                                <field name="active"/>
                            </group>
                        </page>
                        <page string="Ofertes">
                            <field name="offer_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="estate_property_view_filter" model="ir.ui.view">
        <field name="name">estate.property.search</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <search string="Search Property">
                <field name="name"/>
                <field name="property_type_id"/>
                <field name="postcode"/>
                <field name="expected_price"/>
                <field name="state"/>
                <field name="date_availability"/>
                <separator/>
                <filter string="Disponibles" name="available" domain="[('state', 'in', ('new', 'offer_received'))]"/>
                <filter string="Baix preu" name="low_price" domain="[('expected_price', '&lt;', 100000)]"/>
                <group expand="1" string="Group By">
                    <filter string="Tipus" name="group_type" context="{'group_by':'property_type_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="estate_property_action" model="ir.actions.act_window">
        <field name="name">Propietats</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_available': True}</field>
    </record>
</odoo>
